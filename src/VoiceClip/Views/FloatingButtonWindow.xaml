<Window x:Class="VoiceClip.Views.FloatingButtonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceClip"
        Width="80" Height="80"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        Cursor="Hand"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonUp="Window_MouseRightButtonUp"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp">

    <Grid>
        <Ellipse x:Name="ButtonCircle"
                 Width="64" Height="64"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Ellipse.Fill>
                <SolidColorBrush x:Name="ButtonFill" Color="#0078D4"/>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.35" Color="Black"/>
            </Ellipse.Effect>
        </Ellipse>

        <TextBlock x:Name="MicIcon"
                   Text="&#xE720;"
                   FontFamily="Segoe MDL2 Assets"
                   FontSize="28"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"/>
    </Grid>
</Window>
