<Window x:Class="VoiceClip.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VoiceClip Settings"
        Width="450" Height="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Language -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Language:" VerticalAlignment="Center" Margin="0,0,0,12"/>
        <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"
                  SelectedValue="{Binding Language}"
                  SelectedValuePath="Content"
                  x:Name="LanguageComboBox">
            <ComboBoxItem Content="en-US"/>
            <ComboBoxItem Content="ko-KR"/>
            <ComboBoxItem Content="ja-JP"/>
            <ComboBoxItem Content="zh-CN"/>
            <ComboBoxItem Content="de-DE"/>
            <ComboBoxItem Content="fr-FR"/>
            <ComboBoxItem Content="es-ES"/>
        </ComboBox>

        <!-- Silence Timeout -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Silence timeout (sec):" VerticalAlignment="Center" Margin="0,0,0,12"/>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Slider Width="180" Minimum="3" Maximum="60"
                    Value="{Binding SilenceTimeoutSeconds}"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SilenceTimeoutSeconds}" Width="40"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Max History -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Max history entries:" VerticalAlignment="Center" Margin="0,0,0,12"/>
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Slider Width="180" Minimum="50" Maximum="5000"
                    Value="{Binding MaxHistoryEntries}"
                    TickFrequency="50" IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"/>
            <TextBlock Text="{Binding MaxHistoryEntries}" Width="50"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Hotkeys (display only) -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Dictate hotkey:" VerticalAlignment="Center" Margin="0,0,0,12"/>
        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DictateHotkey}" VerticalAlignment="Center" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="History hotkey:" VerticalAlignment="Center" Margin="0,0,0,12"/>
        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding HistoryHotkey}" VerticalAlignment="Center" Margin="0,0,0,12"/>

        <!-- Run on Startup -->
        <CheckBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                  Content="Run on Windows startup"
                  IsChecked="{Binding RunOnStartup}"
                  Margin="0,0,0,12"/>

        <!-- Microphone -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Microphone:" VerticalAlignment="Center" Margin="0,0,0,12"/>
        <ComboBox Grid.Row="6" Grid.Column="1" x:Name="MicrophoneComboBox" Margin="0,0,0,12"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Padding="16,8" Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button Content="Save" Padding="16,8"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
